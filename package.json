    "dashboard:build": "node scripts/build-dashboard.mjs",
    "dashboard": "npm run dashboard:build && electron dist/dashboard/main.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Solana trading bot powered by Claude AI",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.1",
